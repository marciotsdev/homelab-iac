app:
  title: Homelab Backstage
  baseUrl: "http://{{ hostvars['backstage'].ansible_host }}:{{ backstage_port }}"

  # Enable all packages by default, this will discover packages from packages/app/package.json
  packages: all

  extensions:
    # Configure the catalog index page to be the root page, this is normally mounted on /catalog
    - page:catalog:
        config:
          path: /

organization:
  name: Homelab

backend:
  baseUrl: "http://{{ hostvars['backstage'].ansible_host }}:{{ backstage_port }}"
  listen:
    port: {{ backstage_port }}
    host: 0.0.0.0
  csp:
    connect-src: ["'self'", 'http:', 'https:']
    # This deployment is plain HTTP — without this, the default helmet CSP
    # upgrades every asset request to https:, which this server can't answer,
    # leaving the frontend blank (ERR_SSL_PROTOCOL_ERROR on every script/css).
    upgrade-insecure-requests: false
  cors:
    origin: "http://{{ hostvars['backstage'].ansible_host }}:{{ backstage_port }}"
    methods: [GET, HEAD, PATCH, POST, PUT, DELETE]
    credentials: true
  database:
    client: better-sqlite3
    connection:
      directory: "{{ backstage_app_dir }}/data"
  actions:
    pluginSources:
      - auth
      - catalog
      - scaffolder

integrations:
  gitea:
    - host: "{{ hostvars['gitea'].ansible_host }}:{{ gitea_port }}"
      baseUrl: "http://{{ hostvars['gitea'].ansible_host }}:{{ gitea_port }}"
      password: ${GITEA_TOKEN}

proxy: {}

techdocs:
  builder: 'local'
  generator:
    runIn: 'local'
  publisher:
    type: 'local'

auth:
  providers:
    guest:
      dangerouslyAllowOutsideDevelopment: true
  clientIdMetadataDocuments:
    enabled: false

scaffolder:

catalog:
  import:
    entityFilename: catalog-info.yaml
    pullRequestBranchName: backstage-integration
  rules:
    - allow: [Component, System, API, Resource, Location, Group, User]
  locations:
    - type: url
      target: "http://{{ hostvars['gitea'].ansible_host }}:{{ gitea_port }}/{{ gitea_admin_user }}/{{ gitea_demo_repo }}/raw/branch/main/catalog-info.yaml"

kubernetes:

permission:
  enabled: false

jenkins:
  baseUrl: "http://{{ hostvars['jenkins'].ansible_host }}:{{ jenkins_port }}"
  username: "{{ jenkins_admin_user }}"
  apiKey: ${JENKINS_API_TOKEN}

mcpActions:
  name: 'Homelab Backstage'
  description: 'Software catalog for the homelab (Gitea + Jenkins + AWX + containers)'
