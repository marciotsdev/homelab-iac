<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8">
  <title>{{ item.name }} — homelab</title>
  <style>
    body { font-family: system-ui, sans-serif; background: #0f172a; color: #e2e8f0; display: flex; height: 100vh; align-items: center; justify-content: center; }
    .card { text-align: center; padding: 2rem 3rem; border-radius: 12px; background: #1e293b; }
    h1 { color: {{ item.color }}; }
  </style>
</head>
<body>
  <div class="card">
    <h1>{{ item.name }}</h1>
    <p>{{ item.label }}</p>
    <p><small>containers.{{ domain_suffix }}:{{ item.port }}</small></p>
  </div>
</body>
</html>
